# Apex20 Environment Variables Example 🐹

# Database (PostgreSQL - Port: 5420 host, 5432 container)
DATABASE_URL=postgres://apex20:password@localhost:5420/apex20?sslmode=disable
POSTGRES_USER=apex20
POSTGRES_PASSWORD=password
POSTGRES_DB=apex20

# Cache / PubSub (Redis - Port: 6320 host, 6379 container)
REDIS_URL=redis://localhost:6320
REDIS_ADDR=localhost:6320

# Application
PORT=3000
NODE_ENV=development

# Infrastructure
PROMETHEUS_PORT=9020
STORYBOOK_PORT=6020
